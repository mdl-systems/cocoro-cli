{
    "name": "@mdl-systems/cocoro-cli",
    "version": "0.1.0",
    "description": "Terminal CLI for cocoro-core — ローカルAIをターミナルから操作",
    "author": "MDL Systems",
    "license": "MIT",
    "type": "module",
    "bin": {
        "cocoro": "./bin/cocoro.js"
    },
    "scripts": {
        "build": "node ./node_modules/typescript/bin/tsc -p tsconfig.json",
        "dev": "node ./node_modules/typescript/bin/tsc -p tsconfig.json --watch",
        "lint": "node ./node_modules/typescript/bin/tsc --noEmit",
        "test": "node ./node_modules/vitest/vitest.mjs run",
        "test:run": "node ./node_modules/vitest/vitest.mjs run"
    },
    "dependencies": {
        "@inquirer/prompts": "^7.0.0",
        "@mdl-systems/cocoro-sdk": "file:../cocoro-sdk",
        "chalk": "^5.3.0",
        "cli-table3": "^0.6.3",
        "commander": "^12.0.0",
        "cosmiconfig": "^9.0.0",
        "figures": "^6.0.0",
        "ink": "^5.0.1",
        "ink-spinner": "^5.0.0",
        "ora": "^8.0.1",
        "react": "^18.2.0",
        "wrap-ansi": "^9.0.0"
    },
    "devDependencies": {
        "@types/node": "^20.0.0",
        "@types/react": "^18.2.0",
        "typescript": "^5.3.0",
        "vitest": "^1.2.0"
    },
    "engines": {
        "node": ">=18.0.0"
    },
    "keywords": [
        "cocoro",
        "ai",
        "cli",
        "local-ai"
    ],
    "files": [
        "dist",
        "bin"
    ]
}